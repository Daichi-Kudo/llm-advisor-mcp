{
  "name": "llm-advisor-mcp",
  "version": "0.3.1",
  "description": "MCP server for LLM/VLM model selection — benchmarks, pricing, and recommendations with low-token output",
  "type": "module",
  "bin": {
    "llm-advisor-mcp": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "llm",
    "vlm",
    "model-selection",
    "benchmarks",
    "pricing",
    "swe-bench",
    "aider",
    "opencompass",
    "percentile",
    "ai-models"
  ],
  "author": "Cognisant LLC",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
